using System;

class Shape
{
    public virtual void Area()
    {
        Console.WriteLine("Calculating area...");
    }
}
class Circle : Shape
{
    public override void Area()
    {
        Console.WriteLine("Circle Area = PI * r * r");
    }
}
class Rectangle : Shape
{
    public override void Area()
    {
        Console.WriteLine("Rectangle Area = Length * Width");
    }
}
class Triangle : Shape
{
    public override void Area()
    {
        Console.WriteLine("Triangle Area = 0.5 * Base * Height");
    }
}
class Program
{
    static void Main(string[] args)
    {
        Shape s1 = new Circle();
        Shape s2 = new Rectangle();
        Shape s3 = new Triangle();

        s1.Area();
        s2.Area();
        s3.Area();
    }
}