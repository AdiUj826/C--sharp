using System;

class Animal
{
    public virtual void Sound()
    {
        Console.WriteLine("Animal makes a sound");
    }
}

class Dog : Animal
{
    public override void Sound()
    {
        Console.WriteLine("Dog says: Bhauuuu!");
    }
}

class Cat : Animal
{
    public override void Sound()
    {
        Console.WriteLine("Cat says: Meowww!");
    }
}

class Cow : Animal
{
    public override void Sound()
    {
        Console.WriteLine("Cow says: Moooo!");
    }
}

class Program
{
    static void Main(string[] args)
    {
        Animal a1 = new Dog();
        Animal a2 = new Cat();
        Animal a3 = new Cow();

        a1.Sound();
        a2.Sound();
        a3.Sound();
    }
}