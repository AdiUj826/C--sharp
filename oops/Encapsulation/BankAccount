using System;
class BankAccount
{
    private string owner;
    private decimal balance;

    public string Owner
    {
        get { return owner; }
        set { owner = value; }
    }
    public decimal Balance
    {
        get { return balance; }
        set { balance = value; }
    }
    public void Display()
    {
        Console.WriteLine("Owner: " + Owner);
        Console.WriteLine("Balance: " + Balance);
    }
}
class Program
{
    static void Main(string[] args)
    {
        BankAccount b = new BankAccount();
        b.Owner = "Ram";
        b.Balance = 10000;
        b.Display();
    }
}