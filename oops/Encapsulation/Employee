using System;
class Employee
{
    private string name;
    private decimal salary;

    public string Name
    {
        get { return name; }
        set { name = value; }
    }
    public decimal Salary
    {
        get { return salary; }
        set { salary = value; }
    }
    public void Display()
    {
        Console.WriteLine("Name: " + Name);
        Console.WriteLine("Salary: " + Salary);
    }
}
class Program
{
    static void Main(string[] args)
    {
        Employee e = new Employee();
        e.Name = "Aditya";
        e.Salary = 50000;
        e.Display();
    }
}